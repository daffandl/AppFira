    <string name="help_desc">This application helps you record your finances with the help of AI and automatic Google Sheets synchronization.</string>
    <string name="help_usage_title">How to Use:</string>
    <string name="help_usage_steps">1. Connect your Google account in the sync menu.\n2. Use the chat feature to record transactions naturally.\n3. Monitor your spending in the dashboard and history.</string>
    <string name="help_more_title">Need More Help?</string>
    <string name="help_short_desc">How to use, sync guide, and privacy.</string>
    <string name="help_guide_short_desc">Feature guide and Google Sheets sync steps.</string>
    <string name="help_privacy_short_desc">Your data is stored locally and in your personal Google Drive.</string>
    <string name="help_support_response_time">We will reply to your message within 1–2 business days.</string>
    <string name="support_email_label">Email: support@appfira.com</string>
    
    <string name="help_welcome">Welcome to Finance AI!</string>
    <string name="help_features_title">Key Features</string>
    <string name="help_feature_ai">• AI Chat: Record transactions by typing natural messages.</string>
    <string name="help_feature_dashboard">• Dashboard: Real-time visualization of balance and trends.</string>
    <string name="help_feature_sync">• Sync: Full integration with Google Sheets.</string>
    <string name="help_feature_export">• Export: Save transaction history to Excel format.</string>
    <string name="help_sync_guide_title">Sync Guide</string>
    <string name="help_sync_step_1">1. Login: Make sure you are signed in with your Google account.</string>
    <string name="help_sync_step_2">2. Select Spreadsheet: In \'Sheets\' menu, pick an active sheet or create new.</string>
    <string name="help_sync_step_3">3. Enable Sync: Toggle \'Sync to Personal Drive\' to start backing up data.</string>
    <string name="help_sync_step_4">4. Auto-Sync: If enabled, every transaction from chat will be sent instantly to Sheets.</string>
    <string name="help_privacy_title">Security &amp; Privacy</string>
    <string name="help_privacy_desc">Your financial data is entirely yours. Finance AI stores data locally on your device and in your personal Google Drive. We do not use intermediary servers to store your transaction data.</string>
    
