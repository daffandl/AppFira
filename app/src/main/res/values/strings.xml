    <string name="help_desc">Aplikasi ini membantu Anda mencatat keuangan dengan bantuan AI dan sinkronisasi Google Sheets secara otomatis.</string>
    <string name="help_usage_title">Cara Penggunaan:</string>
    <string name="help_usage_steps">1. Hubungkan akun Google Anda di menu sinkronisasi.\n2. Gunakan fitur chat untuk mencatat transaksi secara natural.\n3. Pantau pengeluaran Anda di dashboard dan riwayat.</string>
    <string name="help_more_title">Butuh Bantuan Lebih Lanjut?</string>
    <string name="help_short_desc">Cara penggunaan, panduan sinkronisasi, dan privasi.</string>
    <string name="help_guide_short_desc">Panduan fitur dan langkah sinkronisasi Google Sheets.</string>
    <string name="help_privacy_short_desc">Data Anda tersimpan lokal dan di Google Drive pribadi Anda.</string>
    <string name="help_support_response_time">Kami akan membalas pesan Anda dalam waktu 1–2 hari kerja.</string>
    <string name="support_email_label">Email: support@appfira.com</string>
    
    <string name="help_welcome">Selamat datang di Finance AI!</string>
    <string name="help_features_title">Fitur Utama</string>
    <string name="help_feature_ai">• Chat AI: Catat transaksi hanya dengan mengetik pesan natural.</string>
    <string name="help_feature_dashboard">• Dashboard: Visualisasi saldo dan tren keuangan secara real-time.</string>
    <string name="help_feature_sync">• Sinkronisasi: Integrasi penuh dengan Google Sheets.</string>
    <string name="help_feature_export">• Export: Simpan riwayat transaksi ke format Excel.</string>
    <string name="help_sync_guide_title">Panduan Sinkronisasi</string>
    <string name="help_sync_step_1">1. Login: Pastikan Anda sudah masuk dengan akun Google.</string>
    <string name="help_sync_step_2">2. Pilih Spreadsheet: Di menu \'Sheets\', pilih spreadsheet aktif atau buat baru.</string>
    <string name="help_sync_step_3">3. Aktifkan Sync: Nyalakan \'Sync ke Drive Pribadi\' untuk mulai mencadangkan data.</string>
    <string name="help_sync_step_4">4. Auto-Sync: Jika aktif, setiap transaksi dari chat akan langsung terkirim ke Sheets.</string>
    <string name="help_privacy_title">Keamanan &amp; Privasi</string>
    <string name="help_privacy_desc">Data keuangan Anda sepenuhnya milik Anda. Finance AI menyimpan data di penyimpanan lokal perangkat Anda dan di Google Drive pribadi Anda. Kami tidak memiliki server perantara untuk menyimpan data transaksi Anda.</string>
    
